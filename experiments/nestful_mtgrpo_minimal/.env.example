# =============================================================================
#  .env.example — template for the secrets/config needed on a RunPod resume.
#
#  HOW TO USE (never commit your real .env):
#     cp .env.example .env
#     # edit .env, replace every <...> placeholder with your real value
#     set -a; source .env; set +a   # export all vars into the shell
#
#  SECURITY:
#   - This file contains ONLY placeholders. Do NOT put real tokens here.
#   - Keep your real values in .env (which is gitignored — see note below).
#   - Never paste tokens into chat, logs, or commit messages.
# =============================================================================

# Weights & Biases (training metrics). Get it at https://wandb.ai/authorize
export WANDB_API_KEY="<your_wandb_key>"
# Project to log to (any name). Leaving it set enables W&B logging in the runner.
export WANDB_PROJECT="nestful-mtgrpo"
# Optional: group/entity overrides (leave commented unless you need them).
# export WANDB_ENTITY="<your_wandb_team>"

# Hugging Face token (model download / gated repos). https://huggingface.co/settings/tokens
export HF_TOKEN="<your_hf_token>"
# Some libraries read HUGGING_FACE_HUB_TOKEN instead — mirror it to be safe.
export HUGGING_FACE_HUB_TOKEN="${HF_TOKEN}"

# GPUs to use (4× RTX 4090 / 24GB on this pod).
export CUDA_VISIBLE_DEVICES="0,1,2,3"
