# Generated artifacts for nestful_synthetic_curriculum_v3 (P0 remediation).
# Policy (docs/RUNBOOK.md): never commit model weights, tokenizer dumps, or
# per-sample rollout/prediction files. Small JSON/MD summaries stay committable.
# Note: the repo-root .gitignore already blocks **/outputs/runs/ and *.safetensors;
# these rules make the policy local and explicit, and cover SFT/eval outputs too.

# Model weights / adapters / tokenizer dumps anywhere under outputs
outputs/**/checkpoints/
outputs/**/*.safetensors
outputs/**/*.bin
outputs/**/*.pt
outputs/**/tokenizer.json
outputs/**/vocab.json
outputs/**/merges.txt

# Per-sample dumps (large JSONL): trajectories, predictions, eval subsets
outputs/**/*trajectories*.jsonl
outputs/**/*predictions*.jsonl
outputs/**/validation_subset*.jsonl
outputs/**/data_base/

# Raw logs (summaries in train_summary.json / metrics*.json are enough)
outputs/**/*.log
outputs/**/train_log.jsonl

# SFT run outputs (run_<timestamp> dirs contain adapters + logs)
outputs/sft/**/run_*/

# Eval batches: ignore heavy contents, keep reports/metrics/manifests
outputs/evals/**
!outputs/evals/**/
!outputs/evals/**/BATCH_REPORT.md
!outputs/evals/**/metrics.json
!outputs/evals/**/metrics_official.json
!outputs/evals/**/metrics_unified.json
!outputs/evals/**/manifest.json

# Archived pre-v3.1 run dirs (moved from outputs/runs by cleanup Phase K):
# same policy as outputs/runs — heavy per-run artifacts never enter git.
archive/runs_pre_v3_1/

# Agentic OpenRouter dataset: raw LLM responses + prompt cache are heavy and
# reproducible from the cache/manifest; mock smoke outputs are never data.
data/curriculum_v4_nestful_like_agentic_openrouter/raw/
data/curriculum_v4_nestful_like_agentic_openrouter_mock/

# Multi-GPU worker scratch dirs (launch_multi_gpu_workers.sh): per-worker
# raw/filtered/rejected/manifests + tmux logs are intermediate — only the
# MERGED canonical filtered/*.jsonl (written by merge_agentic_workers.py into
# data/curriculum_v4_nestful_like_agentic_openrouter/) is committable data.
data/agentic_workers/

# Local scratch
__pycache__/
*.pyc
wandb/
