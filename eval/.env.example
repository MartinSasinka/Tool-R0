# Environment variables for eval benchmarks.
# Copy to .env and fill in values. Never commit .env with real credentials.

# OpenAI-compatible endpoint (for openai backend)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=http://localhost:8000/v1

# HuggingFace (for gated datasets, if needed)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# CUDA device selection
# CUDA_VISIBLE_DEVICES=0

# vLLM settings
# VLLM_USE_V1=0
# VLLM_WORKER_MULTIPROC_METHOD=spawn
